# Whitelist mode: ignore everything, then re-include only the institution files.
# ~/.claude contains session history, caches, and credentials-adjacent state —
# none of that may ever be committed.
*
!.gitignore
!README.md
!CLAUDE.md
!rules/
!rules/*.md
# rules/backups/ stays LOCAL (not whitelisted): two machines writing
# same-day backup filenames into a shared repo guarantees merge conflicts.
!agents/
!agents/*.md
!hooks/
!hooks/*.py
!hooks/*.md
!templates/
!templates/*.template
# machine.md is intentionally NOT whitelisted: per-machine, never committed.
